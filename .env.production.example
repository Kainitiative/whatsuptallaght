# ============================================================
# What's Up Tallaght — VPS Production Environment
# ============================================================
# Copy this file to /opt/whatsuptallaght/.env.production
# and fill in real values. NEVER commit .env.production to git.

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# Admin dashboard password (the default is "tallaght-admin" — change this!)
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string. Example:
#   postgresql://wut:password@localhost:5432/wut
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── Storage ───────────────────────────────────────────────────
# "local" stores uploaded files on disk (Docker volume at /data/uploads)
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/data/uploads

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── WhatsApp Cloud API ────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# Must match what you set in the Meta webhook configuration
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ── Facebook Page posting (optional) ─────────────────────────
FACEBOOK_PAGE_ID=977887435417701
FACEBOOK_PAGE_ACCESS_TOKEN=your_long_lived_page_token

# ── Site URL (used for OG tags, absolute links, etc.) ─────────
SITE_URL=https://www.whatsuptallaght.ie

# ── Replit Object Storage (leave blank on VPS — not used) ─────
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
