# ============================================================
# What's Up Tallaght — VPS Production Environment
# ============================================================
# Copy to /opt/whatsuptallaght/.env.production and fill in real values.
# NEVER commit .env.production to git.

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=8081

# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# Admin dashboard login password (change from the default "tallaght-admin")
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Database ──────────────────────────────────────────────────
# PostgreSQL runs natively on the VPS host.
# From inside a Docker container, the host is reachable at 172.17.0.1.
# Create a fresh DB first — see "Database setup" in the deployment notes.
DATABASE_URL=postgresql://wut:REPLACE_PASSWORD@172.17.0.1:5432/wut

# ── Storage ───────────────────────────────────────────────────
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/data/uploads

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── WhatsApp Cloud API ────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ── Facebook Page posting (optional) ─────────────────────────
FACEBOOK_PAGE_ID=977887435417701
FACEBOOK_PAGE_ACCESS_TOKEN=your_long_lived_page_token

# ── Site URL ──────────────────────────────────────────────────
SITE_URL=https://www.whatsuptallaght.ie
